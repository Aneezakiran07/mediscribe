            "min_score_threshold": 8,
            "max_score": 22,
            "key_facts_required": [
              "cvs_symptoms",
              "chest_pain_character"
            ],
            "description": "Acute coronary occlusion causing myocardial necrosis. Chest pain lasting >30 minutes, not relieved by rest or sublingual nitrates. May radiate to arm/jaw/back. Requires emergency reperfusion.",
